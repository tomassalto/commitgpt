{
  "name": "@tomassalto/commitgpt",
  "version": "1.0.4",
  "description": "AI-powered conventional commit message generator using Groq",
  "main": "dist/index.js",
  "bin": {
    "commitgpt": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build && npm run lint",
    "clean": "rimraf dist"
  },
  "keywords": [
    "commit",
    "ai",
    "groq",
    "conventional-commits",
    "git",
    "cli",
    "llm"
  ],
  "author": "tomassalto",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "clipboardy": "^2.3.0",
    "commander": "^14.0.3",
    "groq-sdk": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
